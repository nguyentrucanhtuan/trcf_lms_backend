# --- TRCF LMS deployment env (copy to .env at the compose root, then fill in) ---
# Host ports. Change if they clash with other apps on the box.
BACKEND_PORT=8765
FRONTEND_PORT=3000
# 0.0.0.0 = reachable on the LAN/Tailscale IP. Set 127.0.0.1 to expose only to a
# local reverse proxy / Cloudflare tunnel, then rebuild.
BIND_ADDR=0.0.0.0

# Backend secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-real-secret

# Browser-facing backend URL — baked into the frontend at BUILD time.
# Must be reachable from the user's browser. Rebuild the frontend after changing.
NEXT_PUBLIC_API_URL=https://api.example.com

# Backend CORS allow-list + email links. Must include the frontend origin(s).
CORS_ORIGINS=https://lms.example.com
FRONTEND_URL=https://lms.example.com
